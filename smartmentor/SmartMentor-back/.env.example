# SmartMentor local environment variables
# Copy these names into your PowerShell profile, terminal session, or IDE run configuration.
# Do not put real secrets in committed files.

SMARTMENTOR_DB_HOST=localhost
SMARTMENTOR_DB_PORT=3306
SMARTMENTOR_DB_NAME=smart_mentor
SMARTMENTOR_DB_USERNAME=root
SMARTMENTOR_DB_PASSWORD=

SMARTMENTOR_REDIS_HOST=127.0.0.1
SMARTMENTOR_REDIS_PORT=6379
SMARTMENTOR_REDIS_PASSWORD=
SMARTMENTOR_REDIS_DATABASE=11

SMARTMENTOR_JWT_SECRET=replace-with-a-long-random-secret
SMARTMENTOR_JWT_EXPIRATION=86400000

SMARTMENTOR_MAIL_HOST=smtp.qq.com
SMARTMENTOR_MAIL_PORT=465
SMARTMENTOR_MAIL_USERNAME=
SMARTMENTOR_MAIL_PASSWORD=
SMARTMENTOR_MAIL_PROTOCOL=smtps

SMARTMENTOR_DEEPSEEK_API_KEY=
SMARTMENTOR_DEEPSEEK_BASE_URL=https://api.deepseek.com
SMARTMENTOR_DEEPSEEK_MODEL=deepseek-chat

# 讯飞星火大模型（OpenAI 兼容 HTTP 接口）。API_KEY 填讯飞控制台的 HTTP "APIPassword"。
# 赛题要求 AI 能力优先使用科大讯飞，默认 provider=spark。
SMARTMENTOR_SPARK_API_KEY=
SMARTMENTOR_SPARK_BASE_URL=https://spark-api-open.xf-yun.com
SMARTMENTOR_SPARK_MODEL=4.0Ultra

# 大模型主用提供商：spark（默认，讯飞星火）或 deepseek；主用不可用时自动回退另一家
SMARTMENTOR_LLM_PROVIDER=spark
SMARTMENTOR_LLM_FALLBACK_ENABLED=true

# Set to true for competition demos when the model API or network is unavailable.
SMARTMENTOR_OFFLINE_DEMO_ENABLED=false
